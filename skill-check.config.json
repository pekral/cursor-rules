{
  "roots": [
    "skills"
  ],
  "include": [
    "*/SKILL.md"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/.git/**"
  ],
  "limits": {
    "maxDescriptionChars": 1024,
    "maxBodyLines": 500,
    "minDescriptionChars": 50,
    "maxBodyTokens": 5000,
    "maxNameChars": 64,
    "maxCompatibilityChars": 500
  },
  "rules": {
    "description.use_when_phrase": "warn"
  },
  "allowlist": [],
  "plugins": [],
  "output": {
    "format": "text"
  }
}
